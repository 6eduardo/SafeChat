<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SafeChat.Mobile.ViewModels"
             x:Class="SafeChat.Mobile.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource SafeChatChatBg}"
             Title="Perfil">

    <Grid RowDefinitions="Auto,*">

        <!-- Cabeçalho -->
        <VerticalStackLayout Grid.Row="0"
                             BackgroundColor="{StaticResource SafeChatNavy}"
                             Padding="20,20,20,28"
                             Spacing="12">
            <Label Text="Perfil"
                   FontSize="22"
                   FontFamily="OpenSansSemibold"
                   TextColor="White"
                   HorizontalOptions="Start" />

            <Border WidthRequest="88"
                    HeightRequest="88"
                    BackgroundColor="{StaticResource SafeChatNavyLight}"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    Margin="0,8,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="44" />
                </Border.StrokeShape>
                <Label Text="{Binding Initials}"
                       FontSize="28"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Text="{Binding DisplayName}"
                   FontSize="20"
                   FontAttributes="Bold"
                   FontFamily="OpenSansSemibold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Label Text="{Binding Email}"
                   FontSize="14"
                   TextColor="White"
                   Opacity="0.85"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Conteúdo -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,20,16,24" Spacing="16">

                <!-- Segurança -->
                <Border BackgroundColor="White"
                        Stroke="{StaticResource SafeChatDivider}"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="SEGURANÇA"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource SafeChatLink}"
                               Margin="16,16,16,8" />

                        <!-- Chave pública -->
                        <Grid Padding="16,12"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Chave pública RSA-2048"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SafeChatTextDark}" />
                                <Label Text="Enviada para o servidor"
                                       FontSize="13"
                                       TextColor="{StaticResource SafeChatTextMuted}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource SafeChatInputBg}"
                                    StrokeThickness="0"
                                    Padding="10,6"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Label Text="{Binding PublicKeySnippet}"
                                       FontSize="12"
                                       TextColor="{StaticResource SafeChatTextMuted}" />
                            </Border>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource SafeChatDivider}" Margin="16,0" />

                        <!-- Chave privada -->
                        <Grid Padding="16,12"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Chave privada"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SafeChatTextDark}" />
                                <Label Text="Armazenada localmente"
                                       FontSize="13"
                                       TextColor="{StaticResource SafeChatTextMuted}" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="4"
                                                   VerticalOptions="Center">
                                <Label Text="✓"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SafeChatSuccessGreen}"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding PrivateKeyStatusText}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SafeChatSuccessGreen}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource SafeChatDivider}" Margin="16,0" />

                        <!-- Android Keystore -->
                        <Grid Padding="16,12"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Android Keystore"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SafeChatTextDark}" />
                                <Label Text="Protecção de hardware"
                                       FontSize="13"
                                       TextColor="{StaticResource SafeChatTextMuted}" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="4"
                                                   VerticalOptions="Center">
                                <Label Text="✓"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SafeChatSuccessGreen}"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding KeystoreStatusText}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SafeChatSuccessGreen}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Conta -->
                <Border BackgroundColor="White"
                        Stroke="{StaticResource SafeChatDivider}"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="CONTA"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource SafeChatLink}"
                               Margin="16,16,16,8" />

                        <VerticalStackLayout Padding="16,12" Spacing="2">
                            <Label Text="{Binding DisplayName}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource SafeChatTextDark}" />
                            <Label Text="Nome de utilizador"
                                   FontSize="13"
                                   TextColor="{StaticResource SafeChatTextMuted}" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource SafeChatDivider}" Margin="16,0" />

                        <VerticalStackLayout Padding="16,12" Spacing="2">
                            <Label Text="{Binding Email}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource SafeChatTextDark}" />
                            <Label Text="E-mail"
                                   FontSize="13"
                                   TextColor="{StaticResource SafeChatTextMuted}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Terminar sessão -->
                <Border BackgroundColor="White"
                        Stroke="{StaticResource SafeChatDangerBorder}"
                        StrokeThickness="1"
                        Padding="0"
                        Margin="0,8,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Terminar sessão"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource SafeChatDangerText}"
                           HorizontalOptions="Center"
                           Padding="16,14" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{StaticResource SafeChatNavy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>

</ContentPage>
