<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SafeChat.Mobile.ViewModels"
             x:Class="SafeChat.Mobile.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource SafeChatNavy}">

    <Grid RowDefinitions="Auto,*">

        <!-- Cabeçalho fixo -->
        <VerticalStackLayout
            Grid.Row="0"
            BackgroundColor="{StaticResource SafeChatNavy}"
            Padding="28,48,28,20"
            Spacing="16">

            <Label
                Text="Criar conta"
                FontSize="22"
                FontAttributes="Bold"
                FontFamily="OpenSansSemibold"
                TextColor="White"
                HorizontalOptions="Center"/>

            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="6">
                <BoxView
                    Color="{StaticResource SafeChatProgressInactive}"
                    WidthRequest="48"
                    HeightRequest="4"
                    CornerRadius="2"/>
                <BoxView
                    Color="White"
                    WidthRequest="48"
                    HeightRequest="4"
                    CornerRadius="2"/>
                <BoxView
                    Color="{StaticResource SafeChatProgressInactive}"
                    WidthRequest="48"
                    HeightRequest="4"
                    CornerRadius="2"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>

        <!-- Conteúdo com scroll -->
        <ScrollView Grid.Row="1" BackgroundColor="White">
            <VerticalStackLayout Padding="28,24,28,32" Spacing="0">

                <!-- DADOS PESSOAIS -->
                <Label
                    Text="DADOS PESSOAIS"
                    FontSize="11"
                    FontAttributes="Bold"
                    TextColor="{StaticResource SafeChatSectionLabel}"
                    CharacterSpacing="1"
                    Margin="0,0,0,16"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,16">
                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                        <Label Text="Nome" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource SafeChatTextDark}"/>
                        <Border BackgroundColor="{StaticResource SafeChatInputBg}" Stroke="{StaticResource SafeChatInputBorder}" StrokeThickness="1" Padding="14,0" HeightRequest="48">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Entry Text="{Binding FirstName}" Placeholder="João" PlaceholderColor="{StaticResource SafeChatTextMuted}" TextColor="{StaticResource SafeChatTextDark}" BackgroundColor="Transparent" FontSize="15"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="Apelido" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource SafeChatTextDark}"/>
                        <Border BackgroundColor="{StaticResource SafeChatInputBg}" Stroke="{StaticResource SafeChatInputBorder}" StrokeThickness="1" Padding="14,0" HeightRequest="48">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Entry Text="{Binding LastName}" Placeholder="Silva" PlaceholderColor="{StaticResource SafeChatTextMuted}" TextColor="{StaticResource SafeChatTextDark}" BackgroundColor="Transparent" FontSize="15"/>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <Label Text="Nome de utilizador" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource SafeChatTextDark}" Margin="0,0,0,8"/>
                <Border BackgroundColor="{StaticResource SafeChatInputBg}" Stroke="{StaticResource SafeChatInputBorder}" StrokeThickness="1" Padding="14,0" HeightRequest="48" Margin="0,0,0,16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Entry Text="{Binding Username}" Placeholder="@joao.silva" PlaceholderColor="{StaticResource SafeChatTextMuted}" TextColor="{StaticResource SafeChatTextDark}" BackgroundColor="Transparent" FontSize="15"/>
                </Border>

                <Label Text="E-mail" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource SafeChatTextDark}" Margin="0,0,0,8"/>
                <Border BackgroundColor="{StaticResource SafeChatInputBg}" Stroke="{StaticResource SafeChatInputBorder}" StrokeThickness="1" Padding="14,0" HeightRequest="48" Margin="0,0,0,28">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Entry Text="{Binding Email}" Placeholder="utilizador@email.com" PlaceholderColor="{StaticResource SafeChatTextMuted}" TextColor="{StaticResource SafeChatTextDark}" BackgroundColor="Transparent" Keyboard="Email" FontSize="15"/>
                </Border>

                <!-- SEGURANÇA -->
                <Label
                    Text="SEGURANÇA"
                    FontSize="11"
                    FontAttributes="Bold"
                    TextColor="{StaticResource SafeChatSectionLabel}"
                    CharacterSpacing="1"
                    Margin="0,0,0,16"/>

                <Label Text="Palavra-passe" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource SafeChatTextDark}" Margin="0,0,0,8"/>
                <Border BackgroundColor="{StaticResource SafeChatInputBg}" Stroke="{StaticResource SafeChatInputBorder}" StrokeThickness="1" Padding="14,0" HeightRequest="48" Margin="0,0,0,8">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Entry Text="{Binding Password}" Placeholder="••••••••" PlaceholderColor="{StaticResource SafeChatTextMuted}" TextColor="{StaticResource SafeChatTextDark}" BackgroundColor="Transparent" IsPassword="True" FontSize="15"/>
                </Border>

                <VerticalStackLayout IsVisible="{Binding ShowPasswordStrength}" Spacing="6" Margin="0,0,0,16">
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4">
                        <BoxView Grid.Column="0" Color="{Binding Bar1Color}" HeightRequest="4" CornerRadius="2"/>
                        <BoxView Grid.Column="1" Color="{Binding Bar2Color}" HeightRequest="4" CornerRadius="2"/>
                        <BoxView Grid.Column="2" Color="{Binding Bar3Color}" HeightRequest="4" CornerRadius="2"/>
                        <BoxView Grid.Column="3" Color="{Binding Bar4Color}" HeightRequest="4" CornerRadius="2"/>
                    </Grid>
                    <Label Text="{Binding PasswordStrengthText}" FontSize="13" TextColor="{Binding PasswordStrengthTextColor}"/>
                </VerticalStackLayout>

                <Label Text="Confirmar palavra-passe" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource SafeChatTextDark}" Margin="0,0,0,8"/>
                <Border BackgroundColor="{StaticResource SafeChatInputBg}" Stroke="{StaticResource SafeChatInputBorder}" StrokeThickness="1" Padding="14,0" HeightRequest="48" Margin="0,0,0,28">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Entry Text="{Binding ConfirmPassword}" Placeholder="••••••••" PlaceholderColor="{StaticResource SafeChatTextMuted}" TextColor="{StaticResource SafeChatTextDark}" BackgroundColor="Transparent" IsPassword="True" FontSize="15"/>
                </Border>

                <!-- CHAVES DE ENCRIPTAÇÃO -->
                <Label
                    Text="CHAVES DE ENCRIPTAÇÃO"
                    FontSize="11"
                    FontAttributes="Bold"
                    TextColor="{StaticResource SafeChatSectionLabel}"
                    CharacterSpacing="1"
                    Margin="0,0,0,16"/>

                <Border BackgroundColor="{StaticResource SafeChatInfoBg}" StrokeThickness="0" Padding="14" Margin="0,0,0,12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" BackgroundColor="{StaticResource SafeChatNavy}" StrokeThickness="0" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Par RSA-2048 gerado" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource SafeChatNavy}"/>
                            <Label Text="Chave privada guardada localmente" FontSize="12" TextColor="{StaticResource SafeChatLink}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border BackgroundColor="{StaticResource SafeChatSuccessBg}" StrokeThickness="0" Padding="14" Margin="0,0,0,16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Label Text="Android Keystore – protecção de hardware activa" FontSize="13" TextColor="{StaticResource SafeChatSuccessText}" HorizontalTextAlignment="Center"/>
                </Border>

                <Label Text="Chave pública (enviada ao servidor)" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource SafeChatTextDark}" Margin="0,0,0,8"/>
                <Border BackgroundColor="{StaticResource SafeChatInputBg}" Stroke="{StaticResource SafeChatInputBorder}" StrokeThickness="1" Padding="14,12" Margin="0,0,0,28">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Label Text="{Binding PublicKeyPreview}" FontSize="11" TextColor="{StaticResource SafeChatTextMuted}" LineBreakMode="CharacterWrap"/>
                </Border>

                <!-- Termos -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="0,0,0,24">
                    <CheckBox Grid.Column="0" IsChecked="{Binding AcceptTerms}" Color="{StaticResource SafeChatNavy}" VerticalOptions="Start"/>
                    <Label Grid.Column="1" FontSize="13" VerticalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Concordo com os " TextColor="{StaticResource SafeChatTextDark}"/>
                                <Span Text="Termos de Serviço" TextColor="{StaticResource SafeChatLink}" TextDecorations="Underline"/>
                                <Span Text=" e a " TextColor="{StaticResource SafeChatTextDark}"/>
                                <Span Text="Política de Privacidade" TextColor="{StaticResource SafeChatLink}" TextDecorations="Underline"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Grid>

                <Button
                    Text="Criar conta e gerar chaves"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="White"
                    BackgroundColor="{StaticResource SafeChatNavy}"
                    CornerRadius="10"
                    HeightRequest="52"
                    HorizontalOptions="Fill"
                    Margin="0,0,0,16"
                    Command="{Binding RegisterCommand}"/>

                <ActivityIndicator
                    IsRunning="{Binding IsLoading}"
                    IsVisible="{Binding IsLoading}"
                    Color="{StaticResource SafeChatNavy}"
                    HorizontalOptions="Center"
                    Margin="0,0,0,16"/>

                <Label HorizontalOptions="Center" HorizontalTextAlignment="Center" FontSize="14" Margin="0,0,0,8">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Já tens conta? " TextColor="{StaticResource SafeChatTextDark}"/>
                            <Span Text="Inicia sessão" TextColor="{StaticResource SafeChatLink}" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
