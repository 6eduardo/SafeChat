<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SafeChat.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SafeChat.Mobile.Views"
    Title="SafeChat"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarTitleColor="{StaticResource SafeChatNavy}"
    Shell.TabBarUnselectedColor="{StaticResource SafeChatTextMuted}"
    Shell.TabBarForegroundColor="{StaticResource SafeChatNavy}">

    <ShellContent Route="Splash" ContentTemplate="{DataTemplate views:SplashPage}" />

    <TabBar>
        <ShellContent Title="Chats"
                      Route="Chats"
                      ContentTemplate="{DataTemplate views:ChatsPage}" />
        <ShellContent Title="Conversas"
                      Route="Inicio"
                      ContentTemplate="{DataTemplate views:ConversationsPage}" />
        <ShellContent Title="Perfil"
                      Route="Perfil"
                      ContentTemplate="{DataTemplate views:ProfilePage}" />
    </TabBar>

</Shell>
